    <Method Name="Get" Id="{247be177-5b4e-49f7-805f-7546d6ff5e6b}">
      <Declaration><![CDATA[METHOD Get : BOOL
VAR_INPUT
	destination : ANY;
END_VAR]]></Declaration>
      <Implementation>
