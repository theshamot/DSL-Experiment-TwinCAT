    </Method>
    <Method Name="GetAsType" Id="{c12deb2b-f173-4cec-992e-512d4f2f87db}">
      <Declaration><![CDATA[METHOD GetAsType : BOOL
VAR_INPUT
	destination : __SYSTEM.AnyType;
