  <POU Name="ValueUlintRead" Id="{911ac8c1-62d5-48d6-a4c5-b248d5eb5053}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'linkalways'}
{attribute 'hide_all_locals'}
FUNCTION_BLOCK ValueUlintRead EXTENDS ValueBase IMPLEMENTS ValueRead
