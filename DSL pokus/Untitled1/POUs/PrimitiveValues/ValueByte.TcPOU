    <Method Name="SetFromString" Id="{880f3e3d-fd25-4c42-bb3f-a135d686e515}">
      <Declaration><![CDATA[METHOD SetFromString : BOOL
VAR_INPUT
	value : T_MaxString;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[thisValue := STRING_TO_BYTE(value);

SetFromString := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Set" Id="{d0fa0c61-cdd7-4766-bf96-0bb65b05174e}">
      <Declaration><![CDATA[METHOD Set : BOOL
