    <Method Name="SetFromString" Id="{c0dee8ad-474f-46d4-b03d-f1879a21b722}">
      <Declaration><![CDATA[METHOD SetFromString : BOOL
VAR_INPUT
	value : T_MaxString;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[thisValue := STRING_TO_LTIME(value);

SetFromString := TRUE;]]></ST>
