    <Method Name="SetFromType" Id="{67daa6c9-022e-4330-9f7b-23dadc3700a6}">
      <Declaration><![CDATA[METHOD SetFromType : BOOL
VAR_INPUT
	source : __SYSTEM.AnyType;
