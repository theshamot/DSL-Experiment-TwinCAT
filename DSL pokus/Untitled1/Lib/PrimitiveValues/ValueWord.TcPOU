  <POU Name="ValueWord" Id="{66db54ce-c733-4278-b057-96198b259a5c}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'linkalways'}
{attribute 'hide_all_locals'}
FUNCTION_BLOCK ValueWord EXTENDS ValueWordRead IMPLEMENTS Value
